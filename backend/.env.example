# GhostBusters In The Shell — Backend Configuration
#
# Copy this file to .env:
#   cp .env.example .env
#
# Then edit .env with your settings.

# Database (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5566
DB_NAME=ghostbusters
DB_USER=ghostbusters
DB_PASSWORD=ghostbusters_dev

# Server ports
FLASK_PORT=8066
MCP_PORT=8067

# AI Provider: "claude" or "none"
# Works without an API key — falls back to Python heuristic detection.
# Add ANTHROPIC_API_KEY for AI-powered analysis and rewriting.
AI_PROVIDER=claude

# Anthropic API key (optional)
# Get one at: https://console.anthropic.com/ -> API Keys
# ANTHROPIC_API_KEY=your-key-here
